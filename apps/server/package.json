{
  "name": "@aid/server",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "main": "dist/index.js",
  "scripts": {
    "dev": "tsx src/index.ts",
    "build": "tsc -p tsconfig.json",
    "watch": "tsx watch src/index.ts",
    "start": "node dist/index.js",
    "typecheck": "tsc -p tsconfig.json --noEmit",
    "lint": "prettier --check . --ignore-path ../../.prettierignore && eslint .",
    "lint:fix": "eslint . --fix && prettier --write . --ignore-path ../../.prettierignore"
  },
  "dependencies": {
    "@aid/md": "workspace:*",
    "express": "^5.2.1",
    "mongoose": "^9.0.0",
    "pino": "^10.3.1",
    "zod": "^3.23.0"
  },
  "devDependencies": {
    "@types/express": "^5.0.6",
    "@types/node": "^24.0.0",
    "pino-pretty": "^13.1.3",
    "tsx": "^4.23.1",
    "typescript": "^6.0.0"
  }
}
