{
  "name": "aid",
  "version": "0.0.1",
  "private": true,
  "description": "AID — Data Operation System",
  "type": "module",
  "packageManager": "pnpm@10.23.0",
  "engines": {
    "node": ">=24.0.0"
  },
  "pnpm": {
    "onlyBuiltDependencies": [
      "esbuild"
    ],
    "peerDependencyRules": {
      "allowedVersions": {
        "typescript": "6"
      }
    }
  },
  "scripts": {
    "dev": "concurrently -n server,client -c blue,green \"pnpm --filter @aid/server dev\" \"pnpm --filter @aid/client dev\"",
    "dev:server": "pnpm --filter @aid/server dev",
    "dev:client": "pnpm --filter @aid/client dev",
    "build": "pnpm -r --if-present build",
    "start": "pnpm -r --if-present start",
    "test": "pnpm -r --if-present test",
    "typecheck": "pnpm -r --if-present typecheck",
    "lint": "pnpm -r --if-present lint",
    "lint:fix": "pnpm -r --if-present lint:fix",
    "format": "prettier --write .",
    "format:check": "prettier --check .",
    "clean": "pnpm -r --if-present exec rm -rf dist"
  },
  "devDependencies": {
    "concurrently": "^10.0.0",
    "eslint": "^10.7.0",
    "eslint-config-prettier": "^10.1.8",
    "prettier": "^3.9.6",
    "typescript-eslint": "^8.65.0"
  }
}
