{
  "name": "@aid/mq",
  "version": "0.2.0",
  "private": true,
  "description": "UI-компоненты поверх Quasar 2, сгруппированные по типу: buttons, forms, tables. Согласованные дефолты задают «дизайн-систему mq»",
  "type": "module",
  "exports": {
    "./buttons": {
      "types": "./dist/buttons/index.d.ts",
      "import": "./dist/buttons/index.js"
    },
    "./forms": {
      "types": "./dist/forms/index.d.ts",
      "import": "./dist/forms/index.js"
    },
    "./tables": {
      "types": "./dist/tables/index.d.ts",
      "import": "./dist/tables/index.js"
    },
    "./toolbars": {
      "types": "./dist/toolbars/index.d.ts",
      "import": "./dist/toolbars/index.js"
    }
  },
  "scripts": {
    "build": "vite build && vue-tsc --emitDeclarationOnly -p tsconfig.json",
    "typecheck": "vue-tsc -p tsconfig.json --noEmit",
    "lint": "prettier --check . --ignore-path ../../.prettierignore && eslint .",
    "lint:fix": "eslint . --fix && prettier --write . --ignore-path ../../.prettierignore"
  },
  "peerDependencies": {
    "quasar": "^2.17.0",
    "vue": "^3.5.0"
  },
  "devDependencies": {
    "@vitejs/plugin-vue": "^5.2.1",
    "quasar": "^2.22.0",
    "typescript": "^6.0.0",
    "vite": "^5.4.11",
    "vue": "^3.5.13",
    "vue-tsc": "^2.1.10"
  }
}
