{
  "name": "@aid/mu",
  "version": "0.1.0",
  "private": true,
  "description": "Чистые утилиты, разделённые по типу: array, string, ... Расшариваются между приложениями монорепо",
  "type": "module",
  "main": "dist/index.js",
  "types": "dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    }
  },
  "scripts": {
    "build": "tsc -p tsconfig.json",
    "typecheck": "tsc -p tsconfig.json --noEmit",
    "lint": "prettier --check . --ignore-path ../../.prettierignore && eslint .",
    "lint:fix": "eslint . --fix && prettier --write . --ignore-path ../../.prettierignore"
  },
  "devDependencies": {
    "typescript": "^6.0.0"
  }
}
