{
  "name": "@aid/md",
  "version": "0.1.0",
  "private": true,
  "description": "Модули сущностей: типы, модель, сервис, контроллер, роутер, store-фабрика, форма. Расшариваются между Client и Server",
  "type": "module",
  "exports": {
    "./http-error": {
      "types": "./dist/http-error/index.d.ts",
      "import": "./dist/http-error/index.js"
    },
    "./user/types": {
      "types": "./dist/user/types/index.d.ts",
      "import": "./dist/user/types/index.js"
    },
    "./user/server": {
      "types": "./dist/user/server/index.d.ts",
      "import": "./dist/user/server/index.js"
    },
    "./user/client": {
      "types": "./dist/user/client/index.d.ts",
      "import": "./dist/user/client/index.js"
    }
  },
  "scripts": {
    "build": "vite build && vue-tsc --emitDeclarationOnly -p tsconfig.json",
    "typecheck": "vue-tsc -p tsconfig.json --noEmit",
    "test": "vitest run --root ../.. packages/md",
    "lint": "prettier --check . --ignore-path ../../.prettierignore && eslint .",
    "lint:fix": "eslint . --fix && prettier --write . --ignore-path ../../.prettierignore"
  },
  "peerDependencies": {
    "express": "^5.2.0",
    "mongoose": "^9.0.0",
    "pinia": "^2.0.0",
    "vue": "^3.5.0",
    "zod": "^3.23.0"
  },
  "devDependencies": {
    "@aid/mq": "workspace:*",
    "@types/express": "^5.0.0",
    "@types/node": "^24.0.0",
    "@vitejs/plugin-vue": "^5.2.1",
    "express": "^5.2.1",
    "mongoose": "^9.0.0",
    "pinia": "^2.2.0",
    "typescript": "^6.0.0",
    "vite": "^5.4.0",
    "vue": "^3.5.0",
    "vue-tsc": "^2.1.0",
    "zod": "^3.23.0"
  }
}
